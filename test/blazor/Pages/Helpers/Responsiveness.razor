@page "/responsiveness"

<PageTitle>Responsiveness - Bulma Jumbo Tiny</PageTitle>

<div class="container">
	<section class="hero">
		<div class="hero-body">
			<div class="container">
				<h1 class="title">
					Responsiveness
				</h1>
				<div class="subtitle is-4">
					<p>Bulma is a <strong>mobile-first</strong> framework</p>
				</div>
			</div>
		</div>
